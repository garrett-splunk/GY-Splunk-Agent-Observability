# Copy to secrets.toml and fill in real values. Never commit secrets.toml.

# Ollama (local LLM — no API key required)
ollama_base_url = "http://localhost:11434"
ollama_default_chat_model = "gemma4"

# OpenAI (hosted LLM — required when using Hosted provider in the sidebar)
openai_api_key = "..."
openai_default_chat_model = "gpt-4o"

# Galileo Configuration
galileo_console_url = "https://app.galileo.ai"
galileo_api_key = "..."

# Optional overrides (usually derived from console URL)
# galileo_api_url = "https://api.galileo.ai"
